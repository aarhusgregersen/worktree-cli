{
  "name": "worktree-cli",
  "version": "1.2.0",
  "description": "CLI tool for managing git worktrees with smart environment setup",
  "type": "module",
  "bin": {
    "wtr": "dist/cli.js",
    "worktree-cli": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "git",
    "worktree",
    "cli",
    "developer-tools"
  ],
  "author": "Martin Aarhus Gregersen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aarhusgregersen/worktree-cli.git"
  },
  "bugs": {
    "url": "https://github.com/aarhusgregersen/worktree-cli/issues"
  },
  "homepage": "https://github.com/aarhusgregersen/worktree-cli#readme",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "~5.7.0",
    "vitest": "4.0.18"
  }
}
